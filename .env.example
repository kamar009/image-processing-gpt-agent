OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# 1 = use beta.chat.completions.parse + Pydantic (structured outputs); fallback to json_object on failure
OPENAI_STRUCTURED_PARSE=1
OUTPUT_DIR=./outputs
# Пороги заполнения тома, на котором лежит OUTPUT_DIR (для /internal/health и мониторинга)
DISK_USAGE_WARN_PCT=85
DISK_USAGE_CRITICAL_PCT=95
MAX_PROCESS_SECONDS=10
# Максимальный размер загружаемого изображения (МБ)
MAX_UPLOAD_MB=25
# Предзагрузка rembg при старте (дольше старт, быстрее первый product с удалением фона)
REMBG_WARMUP=0
# Если 1 — предупреждения валидатора (резкость, пересвет) превращаются в ошибки и 422
VALIDATION_WARNINGS_AS_ERRORS=0
# Базовый URL сервиса для абсолютного download_url в JSON (без завершающего слэша)
# PUBLIC_BASE_URL=https://api.example.com
# Docker Compose (proxy на порту 8080): PUBLIC_BASE_URL=http://localhost:8080

# Internal MVP mode (Telegram Mini App + whitelist)
INTERNAL_MODE=0
INTERNAL_DB_PATH=./outputs/internal.db
INTERNAL_ADMIN_IDS=
TELEGRAM_BOT_TOKEN=
WORKER_POLL_SECONDS=3
# Максимум одновременных задач в статусах queued+processing на одного user_id (internal jobs)
INTERNAL_MAX_CONCURRENT_JOBS_PER_USER=3

# Optional Supabase config for production data/auth/storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
